<%- include('../partials/head', { title: 'Nowa przychodnia' }) %>
<%- include('../partials/nav') %>
<main class="container container--narrow">
  <div class="card">
    <h1>Dodaj przychodnię</h1>
    <% if (error) { %><p class="alert alert--error"><%= error %></p><% } %>
    <form method="post" action="/internal/clinics" class="form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="form-group">
        <label for="name">Nazwa przychodni</label>
        <input type="text" id="name" name="name" required minlength="2">
      </div>
      <div class="form-group">
        <label for="taxId">NIP</label>
        <input type="text" id="taxId" name="taxId" required minlength="5">
      </div>
      <div class="form-group">
        <label for="address">Adres (opcjonalnie)</label>
        <input type="text" id="address" name="address">
      </div>
      <button type="submit" class="btn btn--primary">Dodaj przychodnię</button>
    </form>
  </div>
</main>
<%- include('../partials/footer') %>
