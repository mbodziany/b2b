<%- include('../partials/head', { title: 'Zmiana hasła' }) %>
<%- include('../partials/nav') %>
<main class="container container--narrow">
  <div class="card">
    <h1>Ustaw nowe hasło</h1>
    <p class="text-muted">To pierwsze logowanie lub administrator zresetował Twoje hasło. Ustaw nowe, własne hasło, aby kontynuować.</p>
    <% if (error) { %><p class="alert alert--error"><%= error %></p><% } %>
    <form method="post" action="/change-password" class="form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="form-group">
        <label for="newPassword">Nowe hasło</label>
        <input type="password" id="newPassword" name="newPassword" required autocomplete="new-password" minlength="12">
        <p class="form-hint">Minimum 12 znaków, co najmniej jedna litera i jedna cyfra.</p>
      </div>
      <div class="form-group">
        <label for="confirmPassword">Powtórz nowe hasło</label>
        <input type="password" id="confirmPassword" name="confirmPassword" required autocomplete="new-password" minlength="12">
      </div>
      <button type="submit" class="btn btn--primary">Zapisz nowe hasło</button>
    </form>
  </div>
</main>
<%- include('../partials/footer') %>
