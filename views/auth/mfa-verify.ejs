<%- include('../partials/head', { title: 'Weryfikacja MFA' }) %>
<%- include('../partials/nav') %>
<main class="container container--narrow">
  <div class="card">
    <h1>Wprowadź kod uwierzytelniający</h1>
    <p class="text-muted">Otwórz aplikację uwierzytelniającą i wpisz aktualny 6-cyfrowy kod.</p>
    <% if (error) { %><p class="alert alert--error"><%= error %></p><% } %>
    <form method="post" action="/mfa/verify" class="form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="form-group">
        <label for="token">Kod (6 cyfr)</label>
        <input type="text" id="token" name="token" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" required autocomplete="one-time-code" autofocus>
      </div>
      <button type="submit" class="btn btn--primary">Zaloguj się</button>
    </form>
  </div>
</main>
<%- include('../partials/footer') %>
