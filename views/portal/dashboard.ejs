<%- include('../partials/head', { title: 'Pulpit' }) %>
<%- include('../partials/nav') %>
<main class="container">
  <div class="card">
    <h1>Witaj, <%= user.fullName %></h1>
    <p class="text-muted">Z tego miejsca możesz przeglądać dane udostępnione Twojej przychodni.</p>
    <ul class="tile-list">
      <% if (user.canViewInvoices) { %>
        <li><a class="tile" href="/portal/invoices">Faktury i zlecenia</a></li>
      <% } %>
      <% if (user.canViewUsg) { %>
        <li><a class="tile" href="/portal/usg">Badania USG</a></li>
      <% } %>
    </ul>
    <% if (!user.canViewInvoices && !user.canViewUsg) { %>
      <p class="alert alert--info">Twoje konto nie ma jeszcze przypisanych uprawnień do przeglądania danych. Skontaktuj się z administratorem.</p>
    <% } %>
  </div>
</main>
<%- include('../partials/footer') %>
