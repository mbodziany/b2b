# Skopiuj ten plik do .env i wypełnij wartości. .env nigdy nie jest commitowany.

# --- Baza danych ---------------------------------------------------------
# W produkcji dodaj ?sslmode=require.
DATABASE_URL="postgresql://b2b:b2b@localhost:5432/b2b?schema=public"

# --- Sesje ----------------------------------------------------------------
# Generować przez: openssl rand -base64 32
SESSION_SECRET="zmien-mnie-openssl-rand-base64-32"
# Limit bezczynności (minuty) - ciasteczko sesyjne jest "rolling", więc każda
# aktywność je odświeża.
SESSION_IDLE_TIMEOUT_MINUTES=30
# Maksymalny czas życia sesji (godziny) niezależny od aktywności - po jego
# przekroczeniu wymagane jest ponowne logowanie (i MFA).
SESSION_ABSOLUTE_TIMEOUT_HOURS=8

# --- Szyfrowanie danych szczególnej kategorii ------------------------------
# 32-bajtowy klucz w base64. Generować przez: openssl rand -base64 32
# Backupować odrębnie od bazy danych (utrata = utrata dostępu do danych zaszyfrowanych tym kluczem).
FIELD_ENCRYPTION_KEY="zmien-mnie-openssl-rand-base64-32"

# --- Pliki ------------------------------------------------------------------
# Katalog (poza repozytorium) na zaszyfrowanym wolumenie, gdzie przechowywane
# są obrazy USG i załączniki faktur.
STORAGE_ROOT="/var/lib/b2b-portal/storage"

# --- Aplikacja ---------------------------------------------------------------
NODE_ENV=development
PORT=3000
